// Inventory Handlers
let allInventoryItems = [];

async function loadInventory() {
    try {
        const res = await fetch('/api/inventory', { headers: { 'Authorization': `Bearer ${token}` } });
        const items = await res.json();
        allInventoryItems = items;

        // Update Summary Stats
        const total = items.length;
        const low = items.filter(i => i.quantity > 0 && i.quantity <= i.alert_threshold).length;
        const outOfStock = items.filter(i => i.quantity <= 0).length;

        document.getElementById('invTotalCount').innerText = total;
        document.getElementById('invLowCount').innerText = low;
        document.getElementById('invOutCount').innerText = outOfStock;
        document.getElementById('invLastUpdate').innerText = new Date().toLocaleTimeString('zh-TW', { hour12: false });

        renderInventory(items);
    } catch (err) {
        console.error('Failed to load inventory', err);
    }
}

function filterInventory(query) {
    const filtered = allInventoryItems.filter(item =>
        item.name.toLowerCase().includes(query.toLowerCase()) ||
        item.code.toLowerCase().includes(query.toLowerCase())
    );
    renderInventory(filtered);
}

function renderInventory(items) {
    if (!Array.isArray(items)) return;
    const container = document.getElementById('inventoryList');

    if (items.length === 0) {
        container.innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 4rem; color: #9ca3af; background: white; border-radius: 1rem;">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">📦</div>
                    <p>找不到符合條件的品項</p>
                </div>`;
        return;
    }

    let html = '';
    items.forEach(item => {
        const isOut = item.quantity <= 0;
        const isLow = !isOut && item.quantity <= item.alert_threshold;

        html += `
                <div class="inventory-card ${isLow || isOut ? 'low-stock' : ''}">
                    <div class="inv-card-header">
                        <div class="inv-title-area">
                            <span class="inv-sku">${item.code}</span>
                            <h3 style="margin-top: 0.5rem;">${item.name}</h3>
                        </div>
                        <span class="status-badge ${isOut ? 'status-cancelled' : isLow ? 'status-pending' : 'status-confirmed'}">
                            ${isOut ? '🚫 缺貨' : isLow ? '⚠️ 低水位' : '✅ 充足'}
                        </span>
                    </div>
                    
                    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.875rem;">
                            <span style="color: #6b7280;">安全庫存值</span>
                            <span style="font-weight: 600;">${item.alert_threshold}</span>
                        </div>
                        <!-- Simple Progress Bar visual -->
                        <div style="width: 100%; height: 6px; background: #f3f4f6; border-radius: 3px; overflow: hidden; margin-top: 0.5rem;">
                            <div style="width: ${Math.min(100, (item.quantity / (item.alert_threshold * 2)) * 100)}%; height: 100%; background: ${isOut ? '#ef4444' : isLow ? '#f59e0b' : '#10b981'}; transition: width 0.3s ease;"></div>
                        </div>
                    </div>

                    <div class="inv-qty-display">
                        <button class="inv-qty-btn btn-adjust-inv" data-id="${item.id}" data-delta="-1">−</button>
                        <input type="number" id="inv-qty-${item.id}" class="inv-qty-input inp-qty-inv" 
                            value="${item.quantity}" 
                            data-id="${item.id}"
                            data-last-saved="${item.quantity}">
                        <button class="inv-qty-btn btn-adjust-inv" data-id="${item.id}" data-delta="1">+</button>
                    </div>

                    <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                         <button class="btn btn-outline btn-edit-inv" style="flex: 1; padding: 6px; font-size: 11px;" data-id="${item.id}">設定</button>
                         <button class="btn btn-outline btn-delete-inv" style="flex: 1; padding: 6px; font-size: 11px; color: #ef4444; border-color: #fecaca;" 
                            data-id="${item.id}">刪除</button>
                    </div>
                </div>`;
    });
    container.innerHTML = html;
}

