// Central Event Delegation for dynamic buttons
document.addEventListener('click', async (e) => {
    // Bookings
    if (e.target.classList.contains('btn-confirm-booking')) {
        confirmBooking(e.target.getAttribute('data-id'));
    }
    if (e.target.classList.contains('btn-edit-booking')) {
        editBooking(e.target.getAttribute('data-id'));
    }
    
    // Users
    if (e.target.classList.contains('btn-edit-user')) {
        const user = JSON.parse(e.target.getAttribute('data-user'));
        editUser(user);
    }
    if (e.target.classList.contains('btn-delete-user')) {
        deleteUser(e.target.getAttribute('data-id'));
    }
    
    // Work Orders
    if (e.target.classList.contains('btn-view-wo')) {
        viewWorkOrder(e.target.getAttribute('data-id'));
    }
    if (e.target.classList.contains('btn-edit-wo')) {
        editWorkOrder(e.target.getAttribute('data-id'));
    }
    
    // Inventory
    if (e.target.classList.contains('btn-adjust-inv')) {
        const id = e.target.getAttribute('data-id');
        const delta = parseInt(e.target.getAttribute('data-delta'));
        adjustInventory(id, delta);
    }
    if (e.target.classList.contains('btn-edit-inv')) {
        loadInventoryItemForEdit(e.target.getAttribute('data-id'));
    }
    if (e.target.classList.contains('btn-delete-inv')) {
        deleteInventoryItem(e.target.getAttribute('data-id'));
    }
    
    // Rooms
    if (e.target.classList.contains('btn-edit-amenities')) {
        const id = e.target.getAttribute('data-id');
        const name = e.target.getAttribute('data-name');
        const amenities = JSON.parse(e.target.getAttribute('data-amenities'));
        editAmenities(id, name, amenities);
    }
    if (e.target.classList.contains('btn-manage-instances')) {
        const id = e.target.getAttribute('data-id');
        const name = e.target.getAttribute('data-name');
        const hotelId = e.target.getAttribute('data-hotel-id');
        openInstanceModal(id, name, hotelId);
    }
    if (e.target.classList.contains('btn-trigger-upload')) {
        triggerUpload(e.target.getAttribute('data-id'));
    }
    if (e.target.classList.contains('btn-open-gallery')) {
        openGalleryModal(e.target.getAttribute('data-id'), e.target.getAttribute('data-name'));
    }
    if (e.target.classList.contains('btn-delete-room-type')) {
        deleteRoomType(e.target.getAttribute('data-id'));
    }
    if (e.target.classList.contains('btn-delete-instance')) {
        deleteInstance(e.target.getAttribute('data-id'));
    }
    
    // Modal Closers (Universal)
    if (e.target.id === 'btnCancelUser' || e.target.id === 'btnCloseUserModal') closeUserModal();
    if (e.target.id === 'btnCancelInventory' || e.target.id === 'btnCloseInventoryModal') closeInventoryModal();
    if (e.target.id === 'btnCloseWoViewModal') closeWoViewModal();
    if (e.target.id === 'btnCloseInstanceModal') closeInstanceModal();
    if (e.target.id === 'btnCloseGalleryModal') closeGalleryModal();
    if (e.target.id === 'btnCancelAmenities' || e.target.id === 'btnCloseAmenitiesModalTop') closeAmenitiesModal();

    
    // Static Button Listeners
    if (document.getElementById('btnAddNewUser')) {
        document.getElementById('btnAddNewUser').addEventListener('click', () => {
            document.getElementById('userModalTitle').innerText = '新增管理帳號';
            document.getElementById('userForm').reset();
            document.getElementById('editUserId').value = '';
            document.getElementById('userModal').style.display = 'flex';
        });
    }

    if (document.getElementById('btnAddNewInventory')) {
        document.getElementById('btnAddNewInventory').addEventListener('click', () => {
            document.getElementById('inventoryModal').style.display = 'flex';
        });
    }

    if (document.getElementById('btnAddNewWorkOrder')) {
        document.getElementById('btnAddNewWorkOrder').addEventListener('click', () => {
            document.getElementById('woModal').style.display = 'flex';
        });
    }

    if (document.getElementById('btnAddRoomInstance')) {
        document.getElementById('btnAddRoomInstance').addEventListener('click', addRoomInstance);
    }

    if (document.getElementById('btnTriggerGalleryUpload')) {
        document.getElementById('btnTriggerGalleryUpload').addEventListener('click', () => {
            document.getElementById('galleryImageInput').click();
        });
    }

    // Modal Closer Helper
    function closeUserModal() { document.getElementById('userModal').style.display = 'none'; }
    function closeInventoryModal() { document.getElementById('inventoryModal').style.display = 'none'; }
    function closeWoViewModal() { if(document.getElementById('woViewModal')) document.getElementById('woViewModal').style.display = 'none'; }
    function closeInstanceModal() { document.getElementById('roomInstanceModal').style.display = 'none'; }
    function closeGalleryModal() { document.getElementById('galleryModal').style.display = 'none'; }
    function closeAmenitiesModal() { document.getElementById('amenitiesModal').style.display = 'none'; }


</script>
