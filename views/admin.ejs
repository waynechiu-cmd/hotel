function renderGallery(images) {
    const container = document.getElementById('galleryListArea');
    if (images.length === 0) {
        container.innerHTML = '<p style="text-align: center; color: #9ca3af;">尚無圖片</p>';
        return;
    }

    container.innerHTML = `<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 1rem;">
                ${images.map(img => `
                    <div style="position: relative; aspect-ratio: 1; border-radius: 0.5rem; overflow: hidden; border: 1px solid #e5e7eb;">
                        <img src="${img.image_url}" style="width: 100%; height: 100%; object-fit: cover;">
                        <button class="btn-delete-gallery-img" data-id="${img.id}" style="position: absolute; top: 4px; right: 4px; background: rgba(239, 68, 68, 0.9); color: white; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; display: flex; align-items: center; justify-content: center;">×</button>
                    </div>
                `).join('')}
            </div>`;
}

function triggerGalleryUpload() {
    document.getElementById('galleryImageInput').click();
}

async function handleGalleryUpload(event) {
    const file = event.target.files[0];
    if (!file || !paramsForGallery) return;

    const formData = new FormData();
    formData.append('image', file);

    try {
        const res = await fetch(`/api/admin/room-types/${paramsForGallery.id}/images`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
            body: formData
        });

        if (res.ok) {
            loadGallery(paramsForGallery.id);
        } else {
            alert('上傳失敗');
        }
    } catch (err) {
        alert('系統錯誤');
    } finally {
        event.target.value = '';
    }
}

async function deleteGalleryImage(id) {
    if (!confirm('確定要刪除這張圖片嗎？')) return;
    try {
        const res = await fetch(`/api/admin/room-images/${id}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.ok) {
            loadGallery(paramsForGallery.id);
        } else {
            alert('刪除失敗');
        }
    } catch (err) {
        alert('系統錯誤');
    }
}

// Amenities Management
let currentAmenitiesRoomType = null;

function editAmenities(id, name, amenitiesArray) {
    currentAmenitiesRoomType = id;
    document.getElementById('amenitiesModalTitle').innerText = `${name} - 編輯配備`;

    // Convert array to text (one per line)
    const text = Array.isArray(amenitiesArray) ? amenitiesArray.join('') : '';
    document.getElementById('amenitiesTextarea').value = text;

    document.getElementById('amenitiesModal').style.display = 'flex';
}

function closeAmenitiesModal() {
    document.getElementById('amenitiesModal').style.display = 'none';
    currentAmenitiesRoomType = null;
}

async function saveAmenities() {
    if (!currentAmenitiesRoomType) return;

    const text = document.getElementById('amenitiesTextarea').value;
    // Split by newline and filter empty lines
    const amenitiesArray = text.split('')
        .map(line => line.trim())
        .filter(line => line.length > 0);

    try {
        const res = await fetch(`/api/admin/room-types/${currentAmenitiesRoomType}`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ amenities: amenitiesArray })
        });

        if (res.ok) {
            alert('配備已更新');
            closeAmenitiesModal();
            loadRoomTypes();
        } else {
            alert('更新失敗');
        }
    } catch (err) {
        alert('系統錯誤');
    }
}

// ============ BI Dashboard Functions ============
let occupancyChartInstance = null;
let performanceChartInstance = null;

async function loadBIDashboard() {
    try {
        // 1. Summary Data
        const summRes = await fetch('/api/analytics/summary', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const summary = await summRes.json();
        renderBISummary(summary);

        // 2. Fetch Occupancy Chart Data
        const occRes = await fetch('/api/analytics/occupancy', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const occupancyData = await occRes.json();
        renderOccupancyChart(occupancyData);

        // 3. Fetch Performance Chart Data
        const perfRes = await fetch('/api/analytics/performance', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const performanceData = await perfRes.json();
        renderPerformanceChart(performanceData);

    } catch (err) {
        console.error('Dashboard load error:', err);
    }
}

function renderBISummary(data) {
    // Occupancy
    document.getElementById('occRateText').innerText = `${data.occupancyRate}%`;
    document.getElementById('occCountText').innerText = `${data.occupiedCount}/${data.totalRooms} 房間`;
    document.getElementById('occRateBar').style.width = `${data.occupancyRate}%`;

    // Work Orders
    document.getElementById('woRateText').innerText = `${data.woCompletionRate}%`;
    document.getElementById('woCountText').innerText = `${data.resolvedWorkOrders}/${data.totalWorkOrders} 任務`;
    document.getElementById('woRateBar').style.width = `${data.woCompletionRate}%`;

    // Inventory
    const alerts = data.inventoryAlerts || [];
    document.getElementById('invAlertCount').innerText = alerts.length;

    const listEl = document.getElementById('inventoryAlertList');
    if (alerts.length === 0) {
        listEl.innerHTML = '<div style="text-align: center; padding: 2rem; color: #10B981;">✅ 所有品項庫存充足</div>';
        return;
    }

    listEl.innerHTML = alerts.map(item => `
                <div class="inventory-item">
                    <div>
                        <div style="font-weight: 600; font-size: 0.875rem;">${item.name}</div>
                        <div style="font-size: 0.75rem; color: #6B7280;">Code: ${item.code}</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-weight: 700;">${item.quantity}</div>
                        <span class="status-badge ${item.status === 'alert' ? 'badge-danger' : 'badge-warning'}">
                            ${item.status === 'alert' ? '庫存不足' : '接近告警'}
                        </span>
                    </div>
                </div>
            `).join('');
}

function renderOccupancyChart(data) {
    const ctx = document.getElementById('occupancyChart').getContext('2d');

    // Destroy existing chart if it exists
    if (occupancyChartInstance) {
        occupancyChartInstance.destroy();
    }

    occupancyChartInstance = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: data.map(d => d.room_type),
            datasets: [{
                data: data.map(d => d.bookings_count),
                backgroundColor: ['#4F46E5', '#10B981', '#F59E0B', '#EF4444', '#8B5CF6', '#EC4899'],
                borderWidth: 0
            }]
        },
        options: {
            plugins: { legend: { position: 'bottom' } },
            cutout: '70%'
        }
    });
}

function renderPerformanceChart(data) {
    const ctx = document.getElementById('performanceChart').getContext('2d');

    // Destroy existing chart if it exists
    if (performanceChartInstance) {
        performanceChartInstance.destroy();
    }

    performanceChartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: data.map(d => d.staff_name),
            datasets: [{
                label: '平均處理小時',
                data: data.map(d => d.avg_resolution_hours),
                backgroundColor: '#4F46E5',
                borderRadius: 6
            }]
        },
        options: {
            scales: { y: { beginAtZero: true } },
            plugins: { legend: { display: false } }
        }
    });
}

// ============ Staff Work Orders Functions ============
async function loadStaffTasks() {
    try {
        const res = await fetch('/api/work-orders?status=open', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.status === 401) {
            alert('認證失敗，請重新登入');
            return;
        }
        const tasks = await res.json();
        renderStaffTasks(tasks);
    } catch (err) {
        document.getElementById('staffTasksContainer').innerHTML = '<p style="text-align: center; color: red;">載入失敗</p>';
    }
}

function renderStaffTasks(tasks) {
    const container = document.getElementById('staffTasksContainer');
    if (tasks.length === 0) {
        container.innerHTML = '<div style="text-align: center; padding: 4rem 2rem;"><div style="font-size: 4rem; margin-bottom: 1rem;">🎉</div><h3 style="color: #374151; font-weight: 700;">目前沒有待辦事項</h3><p style="color: #6B7280;">稍微休息一下吧！</p></div>';
        return;
    }

    const categoryNames = {
        cleaning: '✨ 房間清潔',
        repair: '🔧 設施維修',
        maintenance: '🛠️ 定期保養',
        other: '📝 其他項目'
    };

    const categoryColors = {
        cleaning: 'badge-cleaning',
        repair: 'badge-repair',
        maintenance: 'badge-maintenance',
        other: 'badge-other'
    };

    container.innerHTML = tasks.map(task => {
        let actionBtn = '';
        let statusClass = '';

        if (task.status === 'pending') {
            statusClass = 'status-pending';
            actionBtn = `<button class="staff-action-btn btn-start" onclick="startStaffTask(${task.id})">🚀 開始處理</button>`;
        } else if (task.status === 'in_progress') {
            statusClass = 'status-in-progress';
            actionBtn = `<button class="staff-action-btn btn-complete" onclick="openCompletionModal(${task.id})">✅ 完成任務</button>`;
        }

        return `
                    <div class="staff-task-card priority-${task.priority} ${statusClass}">
                        <div class="staff-card-header">
                            <div class="staff-meta">
                                <span class="status-badge ${categoryColors[task.category] || 'badge-other'}">${categoryNames[task.category] || task.category}</span>
                                <span class="status-badge" style="background: ${task.status === 'in_progress' ? '#dbeafe' : '#f3f4f6'}; color: ${task.status === 'in_progress' ? '#1e40af' : '#4b5563'}">
                                    ${task.status === 'in_progress' ? '處理中' : '未執行'}
                                </span>
                            </div>
                            <span style="font-size: 0.75rem; color: #9CA3AF;">#${task.ticket_number}</span>
                        </div>
                        
                        <div class="staff-room-title">
                            ${task.room_number ? 'Room ' + task.room_number : '公共區域'}
                        </div>
                        
                        <div class="staff-card-body">
                            ${task.description}
                        </div>

                        <div>
                            ${actionBtn}
                        </div>
                    </div>
                `;
    }).join('');
}

async function startStaffTask(id) {
    try {
        const res = await fetch(`/api/work-orders/${id}`, {
            method: 'PATCH',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ status: 'in_progress' })
        });
        if (res.ok) loadStaffTasks();
    } catch (err) { alert('操作失敗'); }
}

function openCompletionModal(id) {
    document.getElementById('completionWoId').value = id;
    document.getElementById('woCompletionModal').style.display = 'flex';
}

function closeCompletionModal() {
    document.getElementById('woCompletionModal').style.display = 'none';
    document.getElementById('woCompletionForm').reset();
}

document.getElementById('woCompletionForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('completionWoId').value;
    const fileInput = document.getElementById('woCompletionImage');

    if (!fileInput.files[0]) {
        alert('請上傳照片');
        return;
    }

    const formData = new FormData();
    formData.append('status', 'completed');
    formData.append('image', fileInput.files[0]);

    const remarks = document.getElementById('woCompletionRemarks').value;
    if (remarks) {
        formData.append('staffRemarks', remarks);
    }

    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerText = '上傳中...';

    try {
        const res = await fetch(`/api/work-orders/${id}`, {
            method: 'PATCH',
            headers: { 'Authorization': `Bearer ${token}` },
            body: formData
        });
        if (res.ok) {
            closeCompletionModal();
            loadStaffTasks();
        } else {
            alert('上傳失敗');
        }
    } catch (err) {
        alert('系統錯誤');
    } finally {
        btn.disabled = false;
        btn.innerText = '上傳並完成';
    }

