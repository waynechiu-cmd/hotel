    // Inventory Handlers
    let allInventoryItems = [];

    async function loadInventory() {
        try {
            const res = await fetch('/api/inventory', { headers: { 'Authorization': `Bearer ${token}` } });
            if (!res.ok) {
                if (res.status === 403 || res.status === 401) logout();
                throw new Error('Failed to load inventory');
            }
            const items = await res.json();
            allInventoryItems = items;

            updateSummaryStats();
            renderInventory(items);
        } catch (err) {
            console.error('Failed to load inventory', err);
        }
    }

    function updateSummaryStats() {
        if (!Array.isArray(allInventoryItems)) return;
        
        const total = allInventoryItems.length;
        const low = allInventoryItems.filter(i => i.quantity > 0 && i.quantity <= i.alert_threshold).length;
        const outOfStock = allInventoryItems.filter(i => i.quantity <= 0).length;

        const totalEl = document.getElementById('invTotalCount');
        const lowEl = document.getElementById('invLowCount');
        const outEl = document.getElementById('invOutCount');
        const updateEl = document.getElementById('invLastUpdate');

        if (totalEl) totalEl.innerText = total;
        if (lowEl) lowEl.innerText = low;
        if (outEl) outEl.innerText = outOfStock;
        if (updateEl) updateEl.innerText = new Date().toLocaleTimeString('zh-TW', { hour12: false });
    }

    function filterInventory(query) {
        const filtered = allInventoryItems.filter(item =>
            item.name.toLowerCase().includes(query.toLowerCase()) ||
            item.code.toLowerCase().includes(query.toLowerCase())
        );
        renderInventory(filtered);
    }

    function renderInventory(items) {
        if (!Array.isArray(items)) return;
        const container = document.getElementById('inventoryList');

        if (items.length === 0) {
            container.innerHTML = `
            <div style="grid-column: 1/-1; text-align: center; padding: 6rem; color: var(--text-muted); background: white; border-radius: 24px; border: 1px dashed var(--border-color);">
                <div style="font-size: 5rem; margin-bottom: 2rem; opacity: 0.3;">📦</div>
                <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--text-main);">找不到符合條件的品項</h3>
                <p>請嘗試更換關鍵字或新增新品項</p>
            </div>`;
            return;
        }

        let html = '';
        items.forEach(item => {
            const isOut = item.quantity <= 0;
            const isLow = !isOut && item.quantity <= item.alert_threshold;
            const progressPercent = Math.min(100, Math.round((item.quantity / (item.alert_threshold || 1)) * 100));

            html += `
            <div class="inventory-card ${isLow || isOut ? 'low-stock' : ''}" style="border-top: 4px solid ${isOut ? 'var(--accent-red)' : isLow ? '#F59E0B' : 'var(--accent-green)'}">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <div class="text-overline" style="margin-bottom: 4px; display: flex; align-items: center; gap: 4px;">
                            <i class="fas fa-barcode"></i> ${item.code || 'NO SKU'}
                        </div>
                        <h3 style="margin: 0; font-size: 1.25rem; font-weight: 800; color: var(--text-main); line-height: 1.2;">${item.name}</h3>
                    </div>
                    <span class="status-badge ${isOut ? 'status-cancelled' : isLow ? 'status-pending' : 'status-confirmed'}">
                        <i class="fas ${isOut ? 'fa-ban' : isLow ? 'fa-triangle-exclamation' : 'fa-check-circle'}"></i> 
                        ${isOut ? '缺貨' : isLow ? '低水位' : '充足'}
                    </span>
                </div>

                <div style="background: rgba(248, 250, 252, 0.8); padding: 0.625rem 0.875rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.8rem; font-weight: 600; color: #64748B; display: flex; align-items: center; gap: 6px;">
                    <i class="fas fa-tag"></i> ${item.category || '備品 / 耗材'}
                </div>

                <div style="margin-top: auto;">
                    <div class="flex justify-between items-center mb-4">
                        <div class="inventory-qty-control">
                            <button class="inventory-qty-btn btn-adjust-inv" data-id="${item.id}" data-delta="-1" title="減少數量"><i class="fas fa-minus"></i></button>
                            <input type="text" id="inv-qty-${item.id}" class="inventory-qty-input" value="${item.quantity}" readonly data-last-saved="${item.quantity}">
                            <button class="inventory-qty-btn btn-adjust-inv" data-id="${item.id}" data-delta="1" title="增加數量"><i class="fas fa-plus"></i></button>
                        </div>
                        <div class="flex gap-2">
                             <button class="btn btn-outline btn-sm btn-edit-inv" data-id="${item.id}" style="width: 38px; height: 38px; border-radius: 10px; padding: 0; justify-content: center;" title="編輯品項"><i class="fas fa-pen-to-square"></i></button>
                             <button class="btn btn-outline btn-sm btn-delete-inv" data-id="${item.id}" style="width: 38px; height: 38px; border-radius: 10px; padding: 0; justify-content: center; color: var(--accent-red); border-color: #FEE2E2;" title="刪除品項"><i class="fas fa-trash-can"></i></button>
                        </div>
                    </div>

                    <div class="flex justify-between items-center mb-2" style="font-size: 0.75rem; font-weight: 700;">
                        <span style="color: var(--text-muted);">庫存水位 <span style="font-weight: 400;">(閾值: ${item.alert_threshold})</span></span>
                        <span style="color: ${isOut ? 'var(--accent-red)' : isLow ? '#D97706' : 'var(--accent-green)'};">${progressPercent}%</span>
                    </div>
                    <div class="progress-container" style="height: 8px; border-radius: 10px; background: #F1F5F9; margin: 0;">
                        <div style="width: ${progressPercent}%; height: 100%; border-radius: 10px; background: ${isOut ? 'var(--grad-red)' : isLow ? 'var(--grad-primary)' : 'var(--grad-green)'}; transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);"></div>
                    </div>
                </div>
            </div>`;
        });
        container.innerHTML = html;
    }

    async function loadInventoryItemForEdit(id) {
        const item = allInventoryItems.find(i => i.id == id); // Fixed lookup bug
        if (!item) return;
        // Re-use current modal but populate it
        document.getElementById('invName').value = item.name;
        document.getElementById('invCode').value = item.code;
        document.getElementById('invQuantity').value = item.quantity;
        document.getElementById('invThreshold').value = item.alert_threshold;

        // Note: need to handle "Edit" vs "Create" in the modal submission
        // For now just show how it would populate. 
        // I'll update the inventory form handler to support updates.
        openInventoryModal();
        // Change title/button text
        document.querySelector('#inventoryModal h2').innerText = '編輯品項';
