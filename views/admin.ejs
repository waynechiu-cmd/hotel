    // Work Order Modal Handlers
    async function openWorkOrderModal() {
        // Load Rooms
        const roomRes = await fetch('/api/admin/room-instances', { headers: { 'Authorization': `Bearer ${token}` } });
        const rooms = await roomRes.json();
        const roomSelect = document.getElementById('woRoomId');
        roomSelect.innerHTML = '<option value="">-- 非特定房間 --</option>';
        rooms.forEach(r => {
            roomSelect.innerHTML += `<option value="${r.id}">${r.room_number} (${r.room_type})</option>`;
        });

        // Load Staff
        const userRes = await fetch('/api/admin/users', { headers: { 'Authorization': `Bearer ${token}` } });
        const users = await userRes.json();
        const staffSelect = document.getElementById('woAssignedTo');
        staffSelect.innerHTML = '<option value="">-- 請選擇員工 --</option>';
        users.forEach(u => {
            staffSelect.innerHTML += `<option value="${u.id}">${u.full_name} (${u.role})</option>`;
        });

        const el = document.getElementById('workOrderModal');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
