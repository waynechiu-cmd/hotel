                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-size: 12px; color: #6b7280; margin-bottom: 0.5rem;">任務描述</label>
                    <div id="viewDescription"
                        style="padding: 0.75rem; background: #f9fafb; border-radius: 0.5rem; white-space: pre-wrap; font-size: 0.9rem; color: #374151;">
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-size: 12px; color: #6b7280; margin-bottom: 0.5rem;">完工備註
                        (員工)</label>
                    <div id="viewStaffRemarks"
                        style="padding: 0.75rem; background: #f0fdf4; border-radius: 0.5rem; white-space: pre-wrap; font-size: 0.9rem; color: #166534; border: 1px solid #bbf7d0;">
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-size: 12px; color: #6b7280; margin-bottom: 0.5rem;">完工照片</label>
                    <div id="viewPhotoArea"></div>
                </div>

                <div style="text-align: right;">
                    <button id="btnCloseWoViewModal" class="btn btn-primary">關閉</button>
                </div>
            </div>
        </div>
    </main>

<script nonce="<%= nonce %>">
console.log('Admin Core Loaded');
let currentUser = null;
let token = sessionStorage.getItem('adminToken');

// Initial Auth Check
if (token) {
    checkAuth();
}

async function checkAuth() {
    try {
        console.log('[Auth-Debug] Starting checkAuth...');
        const overlay = document.getElementById('loginOverlay');
        const storedUser = sessionStorage.getItem('adminUser');
        console.log('[Auth-Debug] storedUser type:', typeof storedUser, 'length:', storedUser ? storedUser.length : 0);
        currentUser = JSON.parse(storedUser);
        if (!currentUser) throw new Error('No user data');

        console.log('[Auth-Debug] currentUser:', currentUser.email);
        overlay.classList.add('hidden');
        updateUIByPermissions();
        console.log('[Auth-Debug] Loading bookings...');
        await loadBookings();
    } catch (err) {
        console.error('[Auth-Debug] Auth check/init failed:', err);
        const overlay = document.getElementById('loginOverlay');
        if (overlay) overlay.classList.remove('hidden');
        sessionStorage.removeItem('adminToken');
    }
}

function updateUIByPermissions() {
    if (!currentUser) return;
    document.getElementById('userInfo').innerText = `登入者: ${currentUser.fullName}`;

    const perms = currentUser.permissions || [];
    const role = currentUser.role;

    // Default hidden
    const links = ['linkBI', 'linkStaff', 'linkUsers', 'linkRooms', 'linkWorkOrders', 'linkInventory', 'linkBookings'];
    links.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.classList.add('hidden');
            el.classList.remove('flex');
        }
    });

    // Admin always sees everything
    if (role === 'admin' || currentUser.email === 'cch' || currentUser.email === 'cch@cc-house.cc') {
        links.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.classList.remove('hidden');
                el.classList.add('flex');
            }
        });
        return;
    }

    // Show base on strict perms check
    if (perms.includes('bi_dashboard')) {
        const el = document.getElementById('linkBI');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }
    if (perms.includes('staff_pwa')) {
        const el = document.getElementById('linkStaff');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }
    if (perms.includes('admin_bookings')) {
        const el = document.getElementById('linkBookings');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }
    if (perms.includes('admin_rooms')) {
        const el = document.getElementById('linkRooms');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }
    if (perms.includes('admin_work_orders')) {
        const el = document.getElementById('linkWorkOrders');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }
    if (perms.includes('admin_inventory')) {
        const el = document.getElementById('linkInventory');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }
    if (perms.includes('admin_users')) {
        const el = document.getElementById('linkUsers');
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }

    // Managers as a fallback for missing perms (optional, but per user request "沒權限的使用者左側選單會完全看不到" we should be strict)
    // If the user wants strict filtering, we don't grant anything else by role alone.
}

// Login Handler
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.disabled = true;
    btn.innerText = '驗證中...';

    try {
        const res = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                username: document.getElementById('username').value,
                password: document.getElementById('password').value
            })
        });

        console.log('[Login-Debug] res.status:', res.status);
        const data = await res.json();
        console.log('[Login-Debug] data received:', data);
        if (res.ok) {
            console.log('[Login-Debug] Success, storing tokens...');
            sessionStorage.setItem('adminToken', data.token);
            sessionStorage.setItem('adminUser', JSON.stringify(data.user));
            token = data.token;
            console.log('[Login-Debug] Calling checkAuth...');
            await checkAuth();
        } else {
            console.log('[Login-Debug] Login failed:', data.error);
            const errorEl = document.getElementById('loginError');
            errorEl.innerText = data.error || '登入失敗';
            errorEl.classList.remove('hidden');
            errorEl.style.display = 'block'; // Fallback
        }
    } catch (err) {
        alert('登入失敗，伺服器連線問題');
    } finally {
        btn.disabled = false;
        btn.innerText = '登入系統';
    }

function logout() {
    sessionStorage.removeItem('adminToken');
    sessionStorage.removeItem('adminUser');
    location.reload();
}

function showTab(tabName) {
    document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
    document.querySelectorAll('.nav-links a').forEach(link => link.classList.remove('active'));

    // Map tab names to IDs correctly
    let targetTabId = 'tab' + tabName.charAt(0).toUpperCase() + tabName.slice(1);

    // Special cases for tab IDs if they don't match the pattern exactly
    if (tabName === 'biDashboard') targetTabId = 'tabBIDashboard';

    const targetTab = document.getElementById(targetTabId);
    if (targetTab) {
        targetTab.classList.add('active');
    }

    const linkId = 'link' + tabName.charAt(0).toUpperCase() + tabName.slice(1);
    if (document.getElementById(linkId)) {
        document.getElementById(linkId).classList.add('active');
    }

    // Load data based on tab
    if (tabName === 'bookings') loadBookings();
    if (tabName === 'users') loadUsers();
    if (tabName === 'rooms') loadRoomTypes();
    if (tabName === 'workOrders') loadWorkOrders();
    if (tabName === 'inventory') loadInventory();
    if (tabName === 'biDashboard') loadBIDashboard();
    if (tabName === 'staff') loadStaffTasks();

    // Close sidebar on mobile after clicking a link
    if (window.innerWidth <= 768) {
        const sidebar = document.querySelector('.sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        if (sidebar) sidebar.classList.remove('active');
        if (overlay) overlay.classList.remove('active');
    }
}

function toggleSidebar() {
    const sidebar = document.querySelector('.sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    if (sidebar) sidebar.classList.toggle('active');
    if (overlay) overlay.classList.toggle('active');
}

async function loadBookings() {
    try {
        const res = await fetch('/api/bookings', { headers: { 'Authorization': `Bearer ${token}` } });
        if (!res.ok) {
            if (res.status === 403 || res.status === 401) logout();
            throw new Error('Failed to load bookings');
        }
        const bookings = await res.json();
        renderBookings(bookings);
    } catch (err) {
        console.error('loadBookings error:', err);
    }
}

function renderBookings(bookings) {
    if (!Array.isArray(bookings)) return;
    let html = `<table><thead><tr><th>編號</th><th>房型 / 房號</th><th>客人</th><th>特殊需求</th><th>日期</th><th>狀態</th><th>操作</th></tr></thead><tbody>`;
    bookings.forEach(b => {
        html += `<tr>
                    <td>${b.booking_reference}</td>
                    <td>
                        <div style="font-weight: 600;">${b.room_type}</div>
                        <div style="font-size: 11px; color: #6b7280;">${b.room_number || '未分配'}</div>
                    </td>
                    <td>${b.guest_name}</td>
                    <td><div style="font-size: 12px; color: #d97706; max-width: 150px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${b.special_requests || ''}">${b.special_requests || '-'}</div></td>
                    <td>${b.check_in_date.split('T')[0]}</td>

                    <td><span class="status-badge status-${b.status}">${b.status}</span></td>
                    <td>
                        ${b.status === 'pending' ? `<button class="btn btn-primary btn-confirm-booking" style="padding: 4px 8px; font-size: 12px; margin-right: 4px;" data-id="${b.id}">確認</button>` : ''}
                        <button class="btn btn-outline btn-edit-booking" style="padding: 4px 8px; font-size: 12px;" data-id="${b.id}">編輯</button>
                    </td>
                </tr>`;
    });
    html += `</tbody></table>`;
    document.getElementById('bookingsList').innerHTML = html;
}

async function loadUsers() {
    const res = await fetch('/api/admin/users', {
        headers: { 'Authorization': `Bearer ${token}` }
    });
    const users = await res.json();
    renderUsers(users);
}

function renderUsers(users) {
    if (!Array.isArray(users)) return;
    let html = `<table><thead><tr><th>姓名</th><th>Email</th><th>角色</th><th>權限</th><th>操作</th></tr></thead><tbody>`;
    users.forEach(u => {
        const perms = u.permissions || [];
        const userJson = JSON.stringify(u).replace(/"/g, '&quot;');
        html += `<tr>
                    <td>${u.full_name}</td>
                    <td>${u.email}</td>
                    <td><span class="status-badge" style="background:#f3f4f6; color:#374151;">${u.role}</span></td>
                    <td>${perms.map(p => `<span class="permission-tag">${p}</span>`).join('')}</td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <button class="btn btn-outline btn-edit-user" style="padding: 2px 8px; font-size: 12px;" data-user='${userJson}'>編輯</button>
                            <button class="btn btn-outline btn-delete-user" style="padding: 2px 8px; font-size: 12px; color: #ef4444; border-color: #fecaca;" data-id="${u.id}">刪除</button>
                        </div>
                    </td>
                </tr>`;
    });
    html += `</tbody></table>`;
    document.getElementById('usersList').innerHTML = html;
}

async function editUser(user) {
    // Note: If user is passed as string, parse it if needed. 
    // In delegation, we'll parse it before calling this.
    document.getElementById('editUserId').value = user.id;
    document.getElementById('newFullName').value = user.full_name;
    document.getElementById('newEmail').value = user.email;
    document.getElementById('newRole').value = user.role;
    document.getElementById('newPassword').required = false;
    document.getElementById('pwdLabel').innerText = '變更密碼 (不選則不修改)';
    document.getElementById('userModalTitle').innerText = '編輯帳號資料';

    // Reset and Set checkboxes
    const perms = user.permissions || [];
    document.querySelectorAll('input[name="permission"]').forEach(cb => {
        cb.checked = perms.includes(cb.value);
    });

    openUserModal();
}

async function deleteUser(id) {
    if (!confirm('確定要永久刪除此帳號嗎？')) return;
    try {
        const res = await fetch(`/api/admin/users/${id}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.ok) {
            alert('已刪除');
            loadUsers();
        } else {
            const err = await res.json();
            alert('失敗: ' + err.error);
        }
    } catch (e) { alert('系統錯誤'); }
}

let workOrdersData = [];

async function loadWorkOrders() {
    try {
        const res = await fetch('/api/work-orders', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const orders = await res.json();
        workOrdersData = orders;
        renderWorkOrders(orders);
    } catch (error) {
        console.error('Failed to load work orders:', error);
    }
}

function renderWorkOrders(orders) {
    if (!Array.isArray(orders)) return;
    const statusNames = { pending: '未執行', in_progress: '處理中', completed: '已完成' };
    const statusColors = { pending: 'status-pending', in_progress: 'status-confirmed', completed: 'status-completed' };

    let html = `<table><thead><tr><th>派工單號</th><th>地點</th><th>負責人</th><th>狀態</th><th>建立時間</th><th>操作</th></tr></thead><tbody>`;
    orders.forEach(o => {
        html += `<tr>
                    <td>${o.ticket_number}</td>
                    <td>
                        <div style="font-weight: 600;">Room ${o.room_number || '公共區域'}</div>
                        <div style="font-size: 11px; color: #6b7280;">${o.category}</div>
                    </td>
                    <td>${o.assigned_to_name || '未分配'}</td>
                    <td><span class="status-badge" style="background: ${o.status === 'completed' ? '#d1fae5' : o.status === 'in_progress' ? '#dbeafe' : '#fef3c7'}; color: ${o.status === 'completed' ? '#065f46' : o.status === 'in_progress' ? '#1e40af' : '#92400e'}">${statusNames[o.status] || o.status}</span></td>
                    <td>${new Date(o.created_at).toLocaleString('zh-TW', { hour12: false })}</td>
                    <td>
                        <button class="btn btn-outline btn-view-wo" style="padding: 4px 8px; font-size: 12px; margin-right: 4px;" data-id="${o.id}">查看</button>
                        <button class="btn btn-outline btn-edit-wo" style="padding: 4px 8px; font-size: 12px;" data-id="${o.id}">編輯</button>
                    </td>
                </tr>`;
    });
    html += `</tbody></table>`;
    document.getElementById('workOrdersList').innerHTML = html;
}

async function updateWorkOrderStatus(id, status) {
    try {
        const res = await fetch(`/api/work-orders/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
            body: JSON.stringify({ status })
        });
        if (res.ok) {
            loadWorkOrders();
        } else {
            alert('更新失敗：狀態值無效');
        }
    } catch (e) { alert('更新失敗'); }
}

// Work Order Modal Handlers
async function openWorkOrderModal() {
    // Load Rooms
    const roomRes = await fetch('/api/admin/room-instances', { headers: { 'Authorization': `Bearer ${token}` } });
    const rooms = await roomRes.json();
    const roomSelect = document.getElementById('woRoomId');
    roomSelect.innerHTML = '<option value="">-- 非特定房間 --</option>';
    rooms.forEach(r => {
        roomSelect.innerHTML += `<option value="${r.id}">${r.room_number} (${r.room_type})</option>`;
    });

    // Load Staff
    const userRes = await fetch('/api/admin/users', { headers: { 'Authorization': `Bearer ${token}` } });
    const users = await userRes.json();
    const staffSelect = document.getElementById('woAssignedTo');
    staffSelect.innerHTML = '<option value="">-- 請選擇員工 --</option>';
    users.forEach(u => {
        staffSelect.innerHTML += `<option value="${u.id}">${u.full_name} (${u.role})</option>`;
    });

    const el = document.getElementById('workOrderModal');
    if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
}

function closeWorkOrderModal() {
    const el = document.getElementById('workOrderModal');
    if (el) { el.classList.add('hidden'); el.classList.remove('flex'); }
    document.getElementById('workOrderForm').reset();
    document.getElementById('woModalTitle').innerText = '新增派工單';
    document.getElementById('woId').value = '';
}

async function editWorkOrder(id) {
    // Find order from global data or fetch if needed
    let order = workOrdersData.find(o => o.id == id);

    if (!order) {
        // Fallback fetch if not found in global (rare)
        const res = await fetch('/api/work-orders', { headers: { 'Authorization': `Bearer ${token}` } });
        const orders = await res.json();
        order = orders.find(o => o.id == id);
    }

    if (!order) {
        alert('找不到該工單');
        return;
    }

    // Load rooms and staff FIRST
    await openWorkOrderModal();

    // THEN Set modal title and Store order ID 
    // This ensures no modal opening logic overwrites this
    document.getElementById('woModalTitle').innerText = '編輯派工單';
    document.getElementById('woId').value = id.toString(); // Force string

    // Fill in the form
    document.getElementById('woRoomId').value = order.room_id || '';
    document.getElementById('woAssignedTo').value = order.assigned_to || '';
    document.getElementById('woDescription').value = order.description;
    document.getElementById('woCategory').value = order.category || 'cleaning';
    document.getElementById('woPriority').value = order.priority || 'medium';
}

document.getElementById('workOrderForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerText = '處理中...';

    const woId = document.getElementById('woId').value;
    const isEdit = !!woId;

    const data = {
        roomId: document.getElementById('woRoomId').value,
        category: document.getElementById('woCategory').value,
        priority: document.getElementById('woPriority').value,
        assignedTo: document.getElementById('woAssignedTo').value,
        description: document.getElementById('woDescription').value
    };

    try {
        const url = isEdit ? `/api/work-orders/${woId}` : '/api/work-orders';
        const method = isEdit ? 'PATCH' : 'POST';

        const res = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
            body: JSON.stringify(data)
        });

        if (res.ok) {
            alert(isEdit ? '工單更新成功' : '工單已建立並指派');
            closeWorkOrderModal();
            loadWorkOrders();
            if (!isEdit) e.target.reset();
        } else {
            const err = await res.json();
            alert((isEdit ? '更新失敗: ' : '建立失敗: ') + (err.error || '未知錯誤'));
        }
    } catch (err) {
        alert('系統錯誤');
    } finally {
        btn.disabled = false;
        btn.innerText = isEdit ? '儲存變更' : '建立工單';
    }

// View Modal Logic
// View Modal Logic
function viewWorkOrder(id) {
    console.log('Viewing work order:', id);
    const o = workOrdersData.find(x => x.id == id);
    if (!o) {
        console.error('Work order not found in global data', id, workOrdersData);
        return;
    }

