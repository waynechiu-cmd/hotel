                    <span id="viewStatus" class="status-badge"></span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                    <div>
                        <label style="display: block; font-size: 12px; color: #6b7280;">建立時間</label>
                        <div id="viewCreatedAt" style="font-weight: 500;"></div>
                    </div>
                    <div>
                        <label style="display: block; font-size: 12px; color: #6b7280;">類別</label>
                        <div id="viewCategory" style="font-weight: 500;"></div>
                    </div>
                    <div>
                        <label style="display: block; font-size: 12px; color: #6b7280;">地點</label>
                        <div id="viewLocation" style="font-weight: 500;"></div>
                    </div>
                    <div>
                        <label style="display: block; font-size: 12px; color: #6b7280;">負責人</label>
                        <div id="viewAssignedTo" style="font-weight: 500;"></div>
