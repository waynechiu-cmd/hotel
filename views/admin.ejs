    let inventoryDebounceTimers = {};

    function adjustInventory(id, delta) {
        const input = document.getElementById(`inv-qty-${id}`);
        if (!input) return;

        const currentVal = parseInt(input.value) || 0;
        const newVal = Math.max(0, currentVal + delta);
        input.value = newVal;

        // Debounce the update to prevent race conditions
        if (inventoryDebounceTimers[id]) clearTimeout(inventoryDebounceTimers[id]);
        inventoryDebounceTimers[id] = setTimeout(() => {
            updateInventory(id, newVal);
        }, 500);
    }

    async function updateInventory(id, newQty) {
        newQty = parseInt(newQty);
        if (isNaN(newQty) || newQty < 0) return;

        const qtyInput = document.getElementById(`inv-qty-${id}`);
        if (!qtyInput) return;

        // Check if token exists
        if (!token) {
            alert('請先登入系統');
            logout();
            return;
        }

        console.log('[Inventory Debug] Starting update for item', id, 'to quantity', newQty);
        console.log('[Inventory Debug] Current token:', token ? token.substring(0, 20) + '...' : 'NO TOKEN');

        try {
            qtyInput.classList.add('opacity-50');

            const res = await fetch(`/api/inventory/${id}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ quantity: newQty })
            });

            console.log('[Inventory Debug] API response status:', res.status);
            console.log('[Inventory Debug] API response ok:', res.ok);

            qtyInput.classList.remove('opacity-50');

            if (res.ok) {
                try {
                    qtyInput.setAttribute('data-last-saved', newQty);
                    // Reload summary stats without full re-render for smooth experience
                    const item = allInventoryItems.find(i => i.id == id);
                    if (item) item.quantity = newQty;
                    updateSummaryStats();

                    // Update the card's visual state (badges, progress bar)
                    const card = qtyInput.closest('.inventory-card');
                    if (card && item) {  // 確保 item 存在
                        const isOut = newQty <= 0;
                        const isLow = !isOut && newQty <= item.alert_threshold;
                        const newProgressPercent = Math.min(100, Math.round((newQty / (item.alert_threshold || 1)) * 100));

                        console.log('[Inventory Debug] Updating card for item', id, '- new qty:', newQty, 'percent:', newProgressPercent);

                        card.className = `inventory-card ${isLow || isOut ? 'low-stock' : ''}`;
                        const badge = card.querySelector('.status-badge');
                        if (badge) {
                            badge.className = `status-badge ${isOut ? 'status-cancelled' : isLow ? 'status-pending' : 'status-confirmed'}`;
                            badge.innerHTML = isOut ? '<i class="fas fa-ban"></i> 缺貨' : isLow ? '<i class="fas fa-triangle-exclamation"></i> 低水位' : '<i class="fas fa-check-circle"></i> 充足';
                        }
                        
                        // 更新百分比文字 - 使用更精確的選擇器
                        const percentSpans = Array.from(card.querySelectorAll('span')).filter(s => {
                            const text = s.textContent.trim();
                            return text.endsWith('%') && !text.includes('(');
                        });
                        
                        if (percentSpans.length > 0) {
                            const percentSpan = percentSpans[percentSpans.length - 1];
                            console.log('[Inventory Debug] Found percent span, updating to:', newProgressPercent + '%');
                            percentSpan.textContent = newProgressPercent + '%';
                            percentSpan.style.color = isOut ? 'var(--accent-red)' : isLow ? '#D97706' : 'var(--accent-green)';
                        } else {
                            console.error('[Inventory Debug] Could not find percent span in card');
                        }
                        
                        // 更新進度條
                        const progress = card.querySelector('div[style*="transition: width"]');
                        if (progress) {
                            progress.style.width = `${newProgressPercent}%`;
                            progress.style.background = isOut ? 'var(--grad-red)' : isLow ? 'var(--grad-primary)' : 'var(--grad-green)';
                        }
                    }
                    console.log('[Inventory Debug] UI update successful');
                } catch (uiErr) {
                    console.error('[Inventory Debug] UI update error:', uiErr.message);
                    console.error('[Inventory Debug] Stack:', uiErr.stack);
                }
            } else {
                const err = await res.json().catch(() => ({}));
                alert('更新失敗: ' + (err.error || '伺服器錯誤'));
                qtyInput.value = qtyInput.getAttribute('data-last-saved');
            }
        } catch (err) {
            alert('更新失敗: 網路連線問題');
            qtyInput.value = qtyInput.getAttribute('data-last-saved');
            qtyInput.classList.remove('opacity-50');
        }
    }


