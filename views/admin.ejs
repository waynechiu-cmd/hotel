<!DOCTYPE html>
<html lang="zh-TW">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理員後台 - 兆基屋管訂房系統</title>
    <link rel="icon" type="image/jpeg" href="/images/logo.jpg">
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/style-utilities.css">
    <link rel="stylesheet" href="/css/security-patch.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0"></script>
</head>

<body id="adminBody" class="admin-page">

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Mobile Header -->
    <div class="mobile-header">
        <button class="hamburger">☰</button>
        <span style="font-weight: 700; color: #111827;">兆基屋管管理系統</span>
        <div style="width: 40px;"></div> <!-- Spacer -->
    </div>

    <!-- Login Overlay -->
    <div id="loginOverlay">
        <div class="login-card">
            <div style="margin-bottom: 2.5rem;">
                <img src="/images/logo.jpg" alt="Logo"
                    style="height: 64px; width: auto; border-radius: 12px; margin-bottom: 1rem;">
                <h2 style="margin: 0; font-family: 'Outfit', sans-serif;">管理員系統</h2>
                <p style="color: #64748b; margin-top: 0.5rem;">請輸入您的管理帳號密碼</p>
            </div>
            <form id="loginForm">
                <div class="form-group">
                    <label for="username">電子郵件 / 帳號</label>
                    <input type="text" id="username" class="form-input" placeholder="example@cc-house.cc" required>
                </div>
                <div class="form-group">
                    <label for="password">密碼</label>
                    <input type="password" id="password" class="form-input" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn btn-primary w-full" style="margin-top: 1rem;">
                    <span>登入系統</span>
                    <i class="fas fa-arrow-right"></i>
                </button>
                <p id="loginError" class="text-danger text-center mt-4 hidden"></p>
            </form>
        </div>
    </div>

    <!-- User Creation Modal -->
    <div id="userModal" class="modal-overlay">
        <div class="modal-content max-w-lg">
            <h2 id="userModalTitle" class="mb-6">新增管理帳號</h2>
            <form id="userForm">
                <input type="hidden" id="editUserId">
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;">姓名</label>
                    <input type="text" id="newFullName" required
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;">
                </div>
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;">Email (登入帳號)</label>
                    <input type="email" id="newEmail" required
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;">
                </div>
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;" id="pwdLabel">初始密碼</label>
                    <input type="password" id="newPassword"
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;"
                        placeholder="不修改請留白">
                </div>
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;">角色身份</label>
                    <select id="newRole" required
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;">
                        <option value="admin">管理員 (Admin)</option>
                        <option value="manager" selected>經理 (Manager)</option>
                        <option value="staff">房務人員 (Staff)</option>
                        <option value="cleaner">清潔人員 (Cleaner)</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label style="color: #374151;">權限設定</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: 0.5rem;">
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="bi_dashboard"> 營運數據儀表板</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="staff_pwa"> 房務工單系統</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_bookings"> 訂單管理權限</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_rooms"> 房型房間管理</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_work_orders"> 派工管理權限</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_inventory"> 庫存管理權限</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_users"> 帳號權限管理</label>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                    <button id="btnCancelUser" type="button" class="btn btn-outline">取消</button>
                    <button type="submit" class="btn btn-primary">確認建立</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
        <a href="/" class="sidebar-brand">
            <img src="/images/logo.jpg" alt="Logo" style="height: 36px; width: auto; border-radius: 8px;">
            <span style="font-family: 'Outfit', sans-serif;">兆基屋管</span>
        </a>

        <ul class="nav-links">
            <li><a href="#" id="linkBookings" class="active"><i class="fas fa-calendar-check"></i> <span>訂單管理</span></a>
            </li>
            <li><a href="#" id="linkBI" style="display: none;"><i class="fas fa-chart-pie"></i> <span>營運報表</span></a>
            </li>
            <li><a href="#" id="linkStaff" style="display: none;"><i class="fas fa-clipboard-check"></i>
                    <span>房務工單</span></a></li>
            <li><a href="#" id="linkRooms" style="display: none;"><i class="fas fa-hotel"></i> <span>房型管理</span></a>
            </li>
            <li><a href="#" id="linkWorkOrders" style="display: none;"><i class="fas fa-tools"></i>
                    <span>派工系統</span></a></li>
            <li><a href="#" id="linkInventory" style="display: none;"><i class="fas fa-boxes-stacked"></i>
                    <span>庫存資產</span></a></li>
            <li><a href="#" id="linkUsers" style="display: none;"><i class="fas fa-user-shield"></i>
                    <span>權限設定</span></a></li>
        </ul>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar" id="userInitial">A</div>
                <div style="flex: 1; min-width: 0;">
                    <div id="footerUserLabel"
                        style="font-weight: 700; font-size: 0.9375rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: white;">
                        Administrator</div>
                    <div style="font-size: 0.75rem; color: rgba(255,255,255,0.4);">系統管理員</div>
                </div>
            </div>
            <a href="#" id="btnLogout"
                style="color: #fca5a5; text-decoration: none; font-size: 0.875rem; display: flex; align-items: center; gap: 0.625rem; padding: 0.5rem; transition: color 0.2s;">
                <i class="fas fa-sign-out-alt"></i> 登出帳號
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <!-- Bookings Tab -->
        <div id="tabBookings" class="tab-content active">
            <div class="page-header">
                <div class="page-title">
                    <h1>訂單管理總覽</h1>
                    <p>查看並管理所有住客與房間預訂資訊</p>
                </div>
                <div class="flex items-center space-x-2">
                    <button class="btn btn-outline btn-sm"><i class="fas fa-file-export"></i> 匯出報表</button>
                    <button class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> 新增預訂</button>
                </div>
            </div>

            <div class="stat-grid" id="bookingSummaryStats">
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--primary-soft); color: var(--primary-color);"><i
                                class="fas fa-calendar-alt"></i></div>
                        <span class="status-badge" style="background: #F1F5F9; color: #475569;">TOTAL</span>
                    </div>
                    <span class="stat-label">本月總訂單</span>
                    <span class="stat-value" id="countTotalBookings">--</span>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: #FFFBEB; color: #F59E0B;"><i class="fas fa-clock"></i>
                        </div>
                        <span class="status-badge status-pending">PENDING</span>
                    </div>
                    <span class="stat-label">待確認訂單</span>
                    <span class="stat-value" id="countPendingBookings">--</span>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: #ECFDF5; color: #10B981;"><i
                                class="fas fa-check-circle"></i></div>
                        <span class="status-badge status-confirmed">CONFIRMED</span>
                    </div>
                    <span class="stat-label">已確認訂單</span>
                    <span class="stat-value" id="countConfirmedBookings">--</span>
                </div>
            </div>

            <div class="table-container">
                <div id="bookingsList">
                    <div class="spinner"></div>
                </div>
            </div>
        </div>

        <!-- Users Tab -->
        <div id="tabUsers" class="tab-content">
            <header
                style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                <div>
                    <h1>帳號權限管理</h1>
                    <p style="color: #6b7280;">新增員工帳號並設定存取權限</p>
                </div>
                <button id="btnAddNewUser" class="btn btn-primary">+ 新增帳號</button>
            </header>

            <div id="usersList" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
                <div class="spinner"></div>
            </div>
        </div>

        <!-- Rooms Tab -->
        <div id="tabRooms" class="tab-content">
            <header style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h1>房型與房間管理</h1>
                    <p style="color: #6b7280;">管理飯店房型優化、格局描述與具體房間號碼</p>
                </div>
            </header>

            <div id="roomTypesList">
                <div class="spinner"></div>
            </div>
            <input type="file" id="roomImageInput" style="display:none" accept="image/*">
        </div>

        <!-- Work Orders Tab -->
        <div id="tabWorkOrders" class="tab-content" style="display: none;">
            <div class="page-header">
                <div class="page-title">
                    <h1>派工任務系統</h1>
                    <p>飯店清潔、維護與臨時需求的調度中心</p>
                </div>
                <button id="btnAddNewWorkOrder" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i>
                    建立新派工</button>
            </div>

            <div class="stat-grid mb-8">
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-dark); color: white;"><i
                                class="fas fa-ticket-alt"></i></div>
                        <span class="status-badge" style="background: #F1F5F9; color: #475569;">TOTAL</span>
                    </div>
                    <span class="stat-label">累積工單數</span>
                    <span class="stat-value" id="countTotalWO">--</span>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-red); color: white;"><i
                                class="fas fa-hourglass-start"></i></div>
                        <span class="status-badge status-pending">PENDING</span>
                    </div>
                    <span class="stat-label">待處理任務</span>
                    <span class="stat-value" id="countPendingWO" style="color: var(--accent-red);">--</span>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-blue); color: white;"><i
                                class="fas fa-spinner"></i></div>
                        <span class="status-badge" style="background: #E0E7FF; color: #1E40AF;">ACTIVE</span>
                    </div>
                    <span class="stat-label">正在執行中</span>
                    <span class="stat-value" id="countProgressWO" style="color: var(--accent-blue);">--</span>
                </div>
            </div>

            <div class="table-container">
                <div id="workOrdersList">
                    <div class="spinner"></div>
                </div>
            </div>
        </div>

        <!-- Inventory Tab -->
        <div id="tabInventory" class="tab-content">
            <div class="page-header">
                <div class="page-title">
                    <h1>庫存管理中心</h1>
                    <p>即時監控備品數量與低水位預警系統</p>
                </div>
                <button id="btnAddNewInventory" class="btn btn-primary">
                    <i class="fas fa-plus"></i>
                    <span>新增庫存品項</span>
                </button>
            </div>

            <!-- Summary Stats -->
            <div class="stat-grid" id="invSummaryStats">
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-dark); color: white;"><i
                                class="fas fa-cubes"></i></div>
                        <span class="status-badge" style="background: #F1F5F9; color: #475569;">CATALOG</span>
                    </div>
                    <span class="stat-label">品項總數</span>
                    <span class="stat-value" id="invTotalCount">--</span>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-red); color: white;"><i
                                class="fas fa-arrow-down-short-wide"></i></div>
                        <span class="status-badge" style="background: #FEF2F2; color: #EF4444;">LOW STOCK</span>
                    </div>
                    <span class="stat-label">水位過低</span>
                    <span class="stat-value" id="invLowCount" style="color: var(--accent-red);">--</span>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: #1E293B; color: white;"><i
                                class="fas fa-circle-exclamation"></i></div>
                        <span class="status-badge" style="background: #E2E8F0; color: #1E293B;">OUT</span>
                    </div>
                    <span class="stat-label">完全缺貨</span>
                    <span class="stat-value" id="invOutCount" style="color: #1E293B;">--</span>
                </div>
            </div>

            <!-- Controls Row -->
            <div
                style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem;">
                <div
                    style="flex: 1; min-width: 320px; position: relative; box-shadow: var(--shadow-sm); border-radius: 16px;">
                    <i class="fas fa-search"
                        style="position: absolute; left: 1.25rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.9rem;"></i>
                    <input type="text" id="invSearchInput" class="form-input" placeholder="鍵入品項名稱或 SKU 快速檢索..."
                        style="padding-left: 3rem; height: 52px; border-radius: 16px; border: 1px solid var(--border-color); font-size: 0.9375rem; background: white;">
                </div>
                <div class="card"
                    style="padding: 0.75rem 1.5rem; border-radius: 14px; display: flex; align-items: center; gap: 8px; font-size: 0.875rem; color: #64748b; font-weight: 600; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color); background: white;">
                    <div
                        style="width: 8px; height: 8px; border-radius: 50%; background: #10B981; animation: pulse 2s infinite;">
                    </div>
                    即時對帳中: <span id="invLastUpdate" style="color: var(--text-main); font-weight: 700;">剛剛</span>
                </div>
            </div>

            <div id="inventoryList" class="inventory-grid">
                <div class="spinner"></div>
            </div>
        </div>

        <!-- BI Dashboard Tab -->
        <div id="tabBIDashboard" class="tab-content" style="display: none;">
            <div class="page-header">
                <div class="page-title">
                    <h1>營運數據分析</h1>
                    <p>核心指標監控與趨勢告警系統</p>
                </div>
                <div class="flex items-center space-x-2">
                    <button class="btn btn-outline btn-sm" id="btnRefreshBIDashboard"><i class="fas fa-sync-alt"></i>
                        刷新數據</button>
                    <select class="form-input btn-sm" style="width: auto; height: 38px;">
                        <option>最近 7 天</option>
                        <option>最近 30 天</option>
                    </select>
                </div>
            </div>

            <div class="stat-grid">
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-blue); color: white;"><i
                                class="fas fa-door-open"></i></div>
                        <span id="occCountText" style="font-size: 11px; font-weight: 700; color: #4F46E5;">0/0
                            ROOMS</span>
                    </div>
                    <span class="stat-label">當前入住率</span>
                    <div class="stat-value" id="occRateText">--%</div>
                    <div class="progress-container" style="margin-top: 1rem;">
                        <div id="occRateBar" class="progress-bar" style="width: 0%; background: var(--grad-blue);">
                        </div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-green); color: white;"><i
                                class="fas fa-list-check"></i></div>
                        <span id="woCountText" style="font-size: 11px; font-weight: 700; color: #10B981;">0/0
                            TASKS</span>
                    </div>
                    <span class="stat-label">工單結案率</span>
                    <div class="stat-value" id="woRateText">--%</div>
                    <div class="progress-container" style="margin-top: 1rem;">
                        <div id="woRateBar" class="progress-bar" style="width: 0%; background: var(--grad-green);">
                        </div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: var(--grad-red); color: white;"><i
                                class="fas fa-triangle-exclamation"></i></div>
                        <span class="status-badge" style="background: #FEF2F2; color: #EF4444;">ALERT</span>
                    </div>
                    <span class="stat-label">待處理告警項目</span>
                    <div class="stat-value" id="invAlertCount" style="color: var(--accent-red);">--</div>
                    <div style="font-size: 0.75rem; color: #94a3b8; margin-top: 0.5rem;">需補貨品項數量</div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-8">
                <div class="chart-card">
                    <h3><i class="fas fa-chart-pie" style="color: var(--accent-blue);"></i> 房型入住分布</h3>
                    <div style="height: 300px; position: relative;">
                        <canvas id="occupancyChart"></canvas>
                    </div>
                </div>
                <div class="chart-card">
                    <h3><i class="fas fa-chart-bar" style="color: var(--primary-color);"></i> 房務效率 (平均處理時數)</h3>
                    <div style="height: 300px; position: relative;">
                        <canvas id="performanceChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="chart-card mt-6">
                <h3><i class="fas fa-boxes" style="color: var(--accent-red);"></i> 庫存告警明細</h3>
                <div id="inventoryAlertList" class="inventory-list">
                    <div style="text-align: center; padding: 3rem; color: #9CA3AF;">
                        <div class="spinner"></div>
                        <p class="mt-4">正在分析庫存水位...</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Staff Work Orders Tab -->
        <div id="tabStaff" class="tab-content" style="display: none;">
            <div class="page-header">
                <div class="page-title">
                    <h1>房務執行中心</h1>
                    <p>查看並執行指派給您的清潔與維修任務</p>
                </div>
                <button class="btn btn-outline btn-sm" id="btnRefreshStaffTasks"><i class="fas fa-sync-alt"></i>
                    刷新任務</button>
            </div>

            <div id="staffTasksContainer" class="room-type-grid">
                <div style="grid-column: 1/-1; text-align: center; padding: 5rem; color: #9CA3AF;">
                    <div class="spinner"></div>
                    <p class="mt-4">正在取得派工單...</p>
                </div>
            </div>
        </div>


        <!-- Inventory Creation Modal -->
        <div id="inventoryModal" class="modal-overlay">
            <div class="modal-content max-w-xl" style="border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.15);">
                <div style="padding: 2rem 2rem 1.5rem; border-bottom: 1px solid #f0f0f0;">
                    <h2 class="mb-1" style="font-size: 1.5rem; font-weight: 800; color: var(--text-main); margin: 0;">新增庫存品項</h2>
                    <p style="font-size: 0.875rem; color: var(--text-muted); margin: 0; margin-top: 0.25rem;">輸入品項基本資訊與告警設置</p>
                </div>
                
                <form id="inventoryForm" style="padding: 2rem;">
                    <!-- 品名欄位 -->
                    <div class="form-group" style="margin-bottom: 1.5rem;">
                        <label style="display: block; font-weight: 700; font-size: 0.875rem; color: var(--text-main); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="fas fa-box"></i> 品名 <span style="color: var(--accent-red);">*</span>
                        </label>
                        <input type="text" id="invName" required placeholder="例如: 牙刷組、枕套、毛巾..."
