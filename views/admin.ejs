<!DOCTYPE html>
<html lang="zh-TW">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/jpeg" href="/images/logo.jpg">
    <title>管理員後台 - 兆基屋管訂房系統</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/style-utilities.css">
    <link rel="stylesheet" href="/css/security-patch.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body id="adminBody" class="admin-page">

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Mobile Header -->
    <div class="mobile-header">
        <button class="hamburger">☰</button>
        <span style="font-weight: 700; color: #111827;">兆基屋管管理系統</span>
        <div style="width: 40px;"></div> <!-- Spacer -->
    </div>

    <!-- Login Overlay -->
    <div id="loginOverlay">
        <div class="login-card">
            <div style="text-align: center; margin-bottom: 1.5rem;"><img src="/images/logo.jpg" alt="Logo" style="height: 60px; width: auto; border-radius: 5px;"></div>
            <h2 class="text-center mb-4">管理員登入</h2>
            <form id="loginForm">
                <div class="form-group mb-4">
                    <label>帳號</label>
                    <input type="text" id="username" placeholder="請輸入帳號" required>
                </div>
                <div class="form-group mb-4">
                    <label>密碼</label>
                    <input type="password" id="password" placeholder="請輸入密碼" required>
                </div>
                <button type="submit" class="btn btn-primary w-full mb-2">登入系統</button>
                <button id="btnLoginCancel" type="button" class="btn btn-outline w-full">取消</button>
                <p id="loginError" class="text-danger text-center mt-4 hidden"></p>
            </form>
        </div>
    </div>

    <!-- User Creation Modal -->
    <div id="userModal" class="modal-overlay">
        <div class="modal-content max-w-lg">
            <h2 id="userModalTitle" class="mb-6">新增管理帳號</h2>
            <form id="userForm">
                <input type="hidden" id="editUserId">
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;">姓名</label>
                    <input type="text" id="newFullName" required
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;">
                </div>
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;">Email (登入帳號)</label>
                    <input type="email" id="newEmail" required
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;">
                </div>
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;" id="pwdLabel">初始密碼</label>
                    <input type="password" id="newPassword"
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;"
                        placeholder="不修改請留白">
                </div>
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="color: #374151;">角色身份</label>
                    <select id="newRole" required
                        style="width: 100%; color: #1a202c; background: #fff; border: 1px solid #d1d5db; padding: 0.75rem; border-radius: 0.5rem;">
                        <option value="admin">管理員 (Admin)</option>
                        <option value="manager" selected>經理 (Manager)</option>
                        <option value="staff">房務人員 (Staff)</option>
                        <option value="cleaner">清潔人員 (Cleaner)</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label style="color: #374151;">權限設定</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: 0.5rem;">
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="bi_dashboard"> 營運數據儀表板</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="staff_pwa"> 房務工單系統</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_bookings"> 訂單管理權限</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_rooms"> 房型房間管理</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_work_orders"> 派工管理權限</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_inventory"> 庫存管理權限</label>
                        <label style="color: #374151; font-size: 0.875rem; font-weight: normal;"><input type="checkbox"
                                name="permission" value="admin_users"> 帳號權限管理</label>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                    <button id="btnCancelUser" type="button" class="btn btn-outline">取消</button>
                    <button type="submit" class="btn btn-primary">確認建立</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">
        <a href="/" class="sidebar-brand" style="display: flex; align-items: center; gap: 0.75rem;"><img src="/images/logo.jpg" alt="Logo" style="height: 32px; width: auto; border-radius: 4px;"><span>兆基屋管管理系統</span></a>
        <ul class="nav-links">
            <li><a href="#" id="linkBookings" class="active">📑 訂單管理</a></li>
            <li><a href="#" id="linkBI" style="display: none;">📊 營運數據儀表板</a></li>
            <li><a href="#" id="linkStaff" style="display: none;">📋 房務工單系統</a></li>
            <li><a href="#" id="linkRooms" style="display: none;">🏨 房型與房間管理</a></li>
            <li><a href="#" id="linkWorkOrders" style="display: none;">📋 派工管理</a></li>
            <li><a href="#" id="linkInventory" style="display: none;">📦 庫存管理</a></li>
            <li><a href="#" id="linkUsers" style="display: none;">👥 帳號權限管理</a></li>
        </ul>
        <div style="margin-top: auto; padding-top: 1rem; border-top: 1px solid #374151;">
            <p id="userInfo" style="font-size: 0.875rem; color: #9ca3af; margin-bottom: 0.5rem;"></p>
            <a href="#" id="btnLogout" style="color: #ef4444; text-decoration: none; font-size: 0.875rem;">登出</a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Bookings Tab -->
        <div id="tabBookings" class="tab-content active">
            <header
                style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                <div>
                    <h1>訂單管理</h1>
                    <p style="color: #6b7280;">查看並管理所有預訂資訊</p>
                </div>
                <!-- Search/Filter could go here if needed -->
            </header>

            <div id="bookingsList" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
                <div class="spinner"></div>
            </div>
        </div>

        <!-- Users Tab -->
        <div id="tabUsers" class="tab-content">
            <header
                style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                <div>
                    <h1>帳號權限管理</h1>
                    <p style="color: #6b7280;">新增員工帳號並設定存取權限</p>
                </div>
                <button id="btnAddNewUser" class="btn btn-primary">+ 新增帳號</button>
            </header>

            <div id="usersList" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
                <div class="spinner"></div>
            </div>
        </div>

        <!-- Rooms Tab -->
        <div id="tabRooms" class="tab-content">
            <header style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h1>房型與房間管理</h1>
                    <p style="color: #6b7280;">管理飯店房型優化、格局描述與具體房間號碼</p>
                </div>
            </header>

            <div id="roomTypesList">
                <div class="spinner"></div>
            </div>
            <input type="file" id="roomImageInput" style="display:none" accept="image/*">
        </div>

        <!-- Work Orders Tab -->
        <div id="tabWorkOrders" class="tab-content">
            <header
                style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                <div>
                    <h1>派工管理</h1>
                    <p style="color: #6b7280;">管理並追蹤房務派工、設施維修工單</p>
                </div>
                <button id="btnAddNewWorkOrder" class="btn btn-primary">+ 新增工單</button>
            </header>

            <div id="workOrdersList" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
                <div class="spinner"></div>
            </div>
        </div>

        <!-- Inventory Tab -->
        <div id="tabInventory" class="tab-content">
            <header
                style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                <div>
                    <h1 style="font-size: 1.875rem; font-weight: 800; color: #111827; margin: 0;">庫存管理中心</h1>
                    <p style="color: #6b7280; margin-top: 0.25rem;">即時監控備品數量與低水位預警系統</p>
                </div>
                <button id="btnAddNewInventory" class="btn btn-primary"
                    style="padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <span>+ 新增庫存品項</span>
                </button>
            </header>

            <!-- Summary Stats -->
            <div class="inv-summary-grid" id="invSummaryStats">
                <div class="inv-stat-card">
                    <span class="inv-stat-label">總品項數量</span>
                    <span class="inv-stat-value" id="invTotalCount">--</span>
                </div>
                <div class="inv-stat-card" style="border-left: 4px solid #ef4444;">
                    <span class="inv-stat-label">低水位告警</span>
                    <span class="inv-stat-value" id="invLowCount" style="color: #ef4444;">--</span>
                </div>
                <div class="inv-stat-card" style="border-left: 4px solid #111827;">
                    <span class="inv-stat-label">缺貨品項</span>
                    <span class="inv-stat-value" id="invOutCount" style="color: #111827;">--</span>
                </div>
            </div>

            <!-- Controls Row -->
            <div
                style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
                <div class="inv-search-container">
                    <span class="inv-search-icon">🔍</span>
                    <input type="text" id="invSearchInput" class="inv-search-input" placeholder="搜尋品項名稱或 SKU...">
                </div>
                <div style="font-size: 0.875rem; color: #6b7280;">
                    最後更新: <span id="invLastUpdate">剛剛</span>
                </div>
            </div>

            <div id="inventoryList" class="inventory-grid">
                <div class="spinner"></div>
            </div>
        </div>

        <!-- BI Dashboard Tab -->
        <div id="tabBIDashboard" class="tab-content">
            <header style="margin-bottom: 2rem;">
                <h1>營運數據儀表板</h1>
                <p style="color: #6b7280;">核心指標監控與庫存告警系統</p>
            </header>

            <div class="summary-grid">
                <div class="stat-card">
                    <span class="stat-label">當前入住率 (Occupancy)</span>
                    <div class="stat-value" id="occRateText">--%</div>
                    <div style="font-size: 0.75rem; color: #9CA3AF;" id="occCountText">0/0 房間</div>
                    <div class="progress-container">
                        <div id="occRateBar" class="progress-bar" style="width: 0%; background: #4F46E5;"></div>
                    </div>
                </div>

                <div class="stat-card">
                    <span class="stat-label">工單完成率 (Resolution Rate)</span>
                    <div class="stat-value" id="woRateText">--%</div>
                    <div style="font-size: 0.75rem; color: #9CA3AF;" id="woCountText">0/0 任務</div>
                    <div class="progress-container">
                        <div id="woRateBar" class="progress-bar" style="width: 0%; background: #10B981;"></div>
                    </div>
                </div>

                <div class="stat-card">
                    <span class="stat-label">低庫存項目數</span>
                    <div class="stat-value" id="invAlertCount" style="color: #F59E0B;">--</div>
                    <div style="font-size: 0.75rem; color: #9CA3AF;">需補貨或即將用罄</div>
                </div>
            </div>

            <div class="bi-grid">
                <!-- Inventory Alerts -->
                <div class="chart-card">
                    <h3>📦 庫存告警明細</h3>
                    <div id="inventoryAlertList" class="inventory-list">
                        <div style="text-align: center; padding: 2rem; color: #9CA3AF;">載入中...</div>
                    </div>
                </div>

                <!-- Occupancy Chart -->
                <div class="chart-card">
                    <h3>房型入住分布 (Distribution)</h3>
                    <canvas id="occupancyChart" style="max-height: 250px;"></canvas>
                </div>

                <!-- Staff Performance -->
                <div class="chart-card" style="grid-column: span 2;">
                    <h3>房務效率 (平均處理時數)</h3>
                    <canvas id="performanceChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Staff Work Orders Tab -->
        <div id="tabStaff" class="tab-content">
            <header style="margin-bottom: 2rem;">
                <h1>房務工單系統</h1>
                <p style="color: #6b7280;">處理指派給您的工作任務</p>
            </header>

            <div id="staffTasksContainer">
                <div style="text-align: center; color: #6B7280; margin-top: 2rem;">載入中...</div>
            </div>
        </div>


        <!-- Inventory Creation Modal -->
        <div id="inventoryModal" class="modal-overlay">
            <div class="modal-content max-w-lg">
                <h2 class="mb-6">新增庫存品項</h2>
                <form id="inventoryForm">
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>品名</label>
                        <input type="text" id="invName" required placeholder="例如: 牙刷組"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                    </div>
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>代號 (SKU)</label>
                        <input type="text" id="invCode" required placeholder="例如: TB-01"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                        <div class="form-group">
                            <label>初始數量</label>
                            <input type="number" id="invQuantity" value="0" min="0"
                                style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                        </div>
                        <div class="form-group">
                            <label>告警閾值</label>
                            <input type="number" id="invThreshold" value="5" min="0"
                                style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                        </div>
                    </div>
                    <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                        <button id="btnCancelInventory" type="button" class="btn btn-outline">取消</button>
                        <button type="submit" class="btn btn-primary">確認建立</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Room Instance Modal -->
        <div id="roomInstanceModal" class="modal-overlay">
            <div class="modal-content max-w-2xl max-h-80vh overflow-y-auto">
                <div class="flex justify-between items-center mb-6">
                    <h2 id="instanceModalTitle">房間清單</h2>
                    <button id="btnCloseInstanceModal" class="btn btn-outline">關閉</button>
                </div>
                <div id="instanceListArea"></div>
                <hr style="margin: 1.5rem 0;">
                <h3>新增房間</h3>
                <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                    <input type="text" id="newInstanceNumber" placeholder="例如: A01-R1"
                        style="flex: 1; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem;">
                    <button id="btnAddRoomInstance" class="btn btn-primary">新增</button>
                </div>
            </div>
        </div>
        <!-- Gallery Modal -->
        <div id="galleryModal" class="modal-overlay">
            <div class="modal-content max-w-2xl max-h-80vh overflow-y-auto">
                <div class="flex justify-between items-center mb-6">
                    <h2 id="galleryModalTitle">相簿管理</h2>
                    <button id="btnCloseGalleryModal" class="btn btn-outline">關閉</button>
                </div>

                <div style="margin-bottom: 1rem;">
                    <button id="btnTriggerGalleryUpload" class="btn btn-primary">+ 上傳新圖片</button>
                    <input type="file" id="galleryImageInput" style="display:none" accept="image/*">
                </div>

                <div id="galleryListArea"></div>
            </div>
        </div>

        <!-- Amenities Modal -->
        <div id="amenitiesModal" class="modal-overlay">
            <div class="modal-content max-w-2xl max-h-80vh overflow-y-auto">
                <div class="flex justify-between items-center mb-6">
                    <h2 id="amenitiesModalTitle">編輯配備</h2>
                    <button id="btnCloseAmenitiesModalTop" class="btn btn-outline">關閉</button>
                </div>

                <div style="margin-bottom: 1rem;">
                    <p style="color: #6b7280; font-size: 14px; margin-bottom: 1rem;">
                        請輸入房間配備，每行一項。例如：免費 WiFi、空調、電視等。
                    </p>
                    <textarea id="amenitiesTextarea"
                        style="width: 100%; height: 300px; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-family: monospace; color: #1a202c;"
                        placeholder="免費 WiFi&#10;空調&#10;電視&#10;冰箱&#10;熱水壺&#10;吹風機&#10;獨立衛浴"></textarea>
                </div>

                <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                    <button id="btnCancelAmenities" type="button" class="btn btn-outline">取消</button>
                    <button id="btnSaveAmenities" class="btn btn-primary">儲存配備</button>
                </div>
            </div>
        </div>
        <!-- Edit Booking Modal -->
        <div id="editBookingModal" class="modal-overlay">
            <div class="modal-content max-w-lg">
                <h2 class="mb-6">編輯訂單</h2>
                <form id="editBookingForm">
                    <input type="hidden" id="editBookingId">
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>住客姓名</label>
                        <input type="text" id="editGuestName"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                    </div>
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>Email</label>
                        <input type="email" id="editGuestEmail"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                    </div>
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>電話 (Telephone)</label>
                        <input type="text" id="editGuestPhone"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                    </div>
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>手機 (Mobile)</label>
                        <input type="text" id="editGuestMobile"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <div class="form-group">
                            <label>入住日期</label>
                            <input type="date" id="editCheckIn"
                                style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                        </div>
                        <div class="form-group">
                            <label>退房日期</label>
                            <input type="date" id="editCheckOut"
                                style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>狀態</label>
                        <select id="editStatus"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                            <option value="pending">待確認 (Pending)</option>
                            <option value="confirmed">已確認 (Confirmed)</option>
                            <option value="completed">已完成 (Completed)</option>
                            <option value="cancelled">已取消 (Cancelled)</option>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>特殊需求</label>
                        <textarea id="editSpecialRequests"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px; height: 60px;"></textarea>
                    </div>
                    <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 1.5rem;">
                        <button id="btnCancelEditBooking" type="button" class="btn btn-outline">取消</button>
                        <button type="submit" class="btn btn-primary">儲存變更</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Work Order Creation Modal -->
        <div id="workOrderModal" class="modal-overlay">
            <div class="modal-content max-w-lg">
                <h2 id="woModalTitle" class="mb-6">新增派工單</h2>
                <form id="workOrderForm">
                    <input type="hidden" id="woId">
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>相關房號 (選填)</label>
                        <select id="woRoomId"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                            <option value="">-- 非特定房間 --</option>
                        </select>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <div class="form-group">
                            <label>派工類別</label>
                            <select id="woCategory" required
                                style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
                                <option value="cleaning">房間清潔</option>
                                <option value="repair">設施維修</option>
