async function updateRoomType(id, field, value) {
    // Find current data
    const resData = await fetch('/api/admin/room-types', { headers: { 'Authorization': `Bearer ${token}` } });
    const allTypes = await resData.json();
    const type = allTypes.find(t => t.id === id);

    const updated = { ...type, [field]: value };

    try {
        const res = await fetch(`/api/admin/room-types/${id}`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(updated)
        });
        if (res.ok) {
            console.log('Updated successfully');
        }
    } catch (err) {
        alert('更新失敗');
    }
}

