            event.target.value = '';
        }
    }

    async function deleteGalleryImage(id) {
        if (!confirm('確定要刪除這張圖片嗎？')) return;
        try {
            const res = await fetch(`/api/admin/room-images/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                loadGallery(paramsForGallery.id);
            } else {
                alert('刪除失敗');
            }
        } catch (err) {
            alert('系統錯誤');
        }
    }

    // Amenities Management
    let currentAmenitiesRoomType = null;

    function editAmenities(id, name, amenitiesArray) {
        currentAmenitiesRoomType = id;
        document.getElementById('amenitiesModalTitle').innerText = `${name} - 編輯配備`;

        // Convert array to text (one per line)
        const text = Array.isArray(amenitiesArray) ? amenitiesArray.join('\n') : '';
        document.getElementById('amenitiesTextarea').value = text;

        document.getElementById('amenitiesModal').style.display = 'flex';
    }

    function closeAmenitiesModal() {
        document.getElementById('amenitiesModal').style.display = 'none';
        currentAmenitiesRoomType = null;
    }

    async function saveAmenities() {
        if (!currentAmenitiesRoomType) return;

        const text = document.getElementById('amenitiesTextarea').value;
        // Split by newline and filter empty lines
        const amenitiesArray = text.split('\n')
            .map(line => line.trim())
            .filter(line => line.length > 0);

        try {
            const res = await fetch(`/api/admin/room-types/${currentAmenitiesRoomType}`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ amenities: amenitiesArray })
            });

            if (res.ok) {
                alert('配備已更新');
                closeAmenitiesModal();
                loadRoomTypes();
            } else {
                alert('更新失敗');
            }
        } catch (err) {
            alert('系統錯誤');
        }
    }

    // ============ BI Dashboard Functions ============
    let occupancyChartInstance = null;
    let performanceChartInstance = null;

    async function loadBIDashboard() {
        try {
            // 1. Summary Data
            const summRes = await fetch('/api/analytics/summary', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const summary = await summRes.json();
            renderBISummary(summary);

            // 2. Fetch Occupancy Chart Data
            const occRes = await fetch('/api/analytics/occupancy', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const occupancyData = await occRes.json();
            renderOccupancyChart(occupancyData);

            // 3. Fetch Performance Chart Data
            const perfRes = await fetch('/api/analytics/performance', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const performanceData = await perfRes.json();
            renderPerformanceChart(performanceData);

        } catch (err) {
            console.error('Dashboard load error:', err);
        }
    }

    function renderBISummary(data) {
        // Occupancy
        document.getElementById('occRateText').innerText = `${data.occupancyRate}%`;
        document.getElementById('occCountText').innerText = `${data.occupiedCount}/${data.totalRooms} 房間`;
        document.getElementById('occRateBar').style.width = `${data.occupancyRate}%`;

        // Work Orders
        document.getElementById('woRateText').innerText = `${data.woCompletionRate}%`;
        document.getElementById('woCountText').innerText = `${data.resolvedWorkOrders}/${data.totalWorkOrders} 任務`;
        document.getElementById('woRateBar').style.width = `${data.woCompletionRate}%`;

        // Inventory
        const alerts = data.inventoryAlerts || [];
        document.getElementById('invAlertCount').innerText = alerts.length;

        const listEl = document.getElementById('inventoryAlertList');
        if (alerts.length === 0) {
            listEl.innerHTML = '<div style="text-align: center; padding: 2rem; color: #10B981;">✅ 所有品項庫存充足</div>';
            return;
        }

        listEl.innerHTML = alerts.map(item => `
                <div class="inventory-item">
                    <div>
                        <div style="font-weight: 600; font-size: 0.875rem;">${item.name}</div>
                        <div style="font-size: 0.75rem; color: #6B7280;">Code: ${item.code}</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-weight: 700;">${item.quantity}</div>
                        <span class="status-badge ${item.status === 'alert' ? 'badge-danger' : 'badge-warning'}">
                            ${item.status === 'alert' ? '庫存不足' : '接近告警'}
                        </span>
                    </div>
                </div>
            `).join('');
    }

    function renderOccupancyChart(data) {
        const ctx = document.getElementById('occupancyChart').getContext('2d');

        // Destroy existing chart if it exists
        if (occupancyChartInstance) {
            occupancyChartInstance.destroy();
        }

        occupancyChartInstance = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: data.map(d => d.room_type),
                datasets: [{
                    data: data.map(d => d.bookings_count),
                    backgroundColor: ['#4F46E5', '#10B981', '#F59E0B', '#EF4444', '#8B5CF6', '#EC4899'],
                    borderWidth: 0
                }]
            },
            options: {
                plugins: { legend: { position: 'bottom' } },
                cutout: '70%'
            }
        });
    }

    function renderPerformanceChart(data) {
        const ctx = document.getElementById('performanceChart').getContext('2d');

        // Destroy existing chart if it exists
        if (performanceChartInstance) {
            performanceChartInstance.destroy();
        }

        performanceChartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: data.map(d => d.staff_name),
                datasets: [{
                    label: '平均處理小時',
                    data: data.map(d => d.avg_resolution_hours),
                    backgroundColor: '#4F46E5',
                    borderRadius: 6
                }]
            },
            options: {
                scales: { y: { beginAtZero: true } },
                plugins: { legend: { display: false } }
            }
        });
    }

    // ============ Staff Work Orders Functions ============
    async function loadStaffTasks() {
        try {
            const res = await fetch('/api/work-orders?status=open', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.status === 401) {
                alert('認證失敗，請重新登入');
                return;
            }
            const tasks = await res.json();
            renderStaffTasks(tasks);
        } catch (err) {
            document.getElementById('staffTasksContainer').innerHTML = '<p style="text-align: center; color: red;">載入失敗</p>';
        }
    }

    function renderStaffTasks(tasks) {
        const container = document.getElementById('staffTasksContainer');
        if (tasks.length === 0) {
            container.innerHTML = `
            <div style="grid-column: 1/-1; text-align: center; padding: 6rem 2rem; background: white; border-radius: 24px; border: 1px dashed var(--border-color);">
                <div style="font-size: 4rem; margin-bottom: 1.5rem;">🎉</div>
                <h3 style="color: var(--text-main); font-weight: 800; font-size: 1.5rem;">目前沒有待辦事項</h3>
                <p style="color: var(--text-muted); font-size: 1.125rem;">稍微休息一下，保持優質服務！</p>
            </div>`;
            return;
        }

        const categoryNames = { cleaning: '房間清潔', repair: '設施維修', maintenance: '定期保養', other: '其他項目' };
        const categoryIcons = { cleaning: 'fa-broom', repair: 'fa-tools', maintenance: 'fa-calendar-check', other: 'fa-clipboard-list' };

        container.innerHTML = tasks.map(task => {
            let actionBtn = '';
            let statusLabel = '';
            let statusColor = '';

            if (task.status === 'pending') {
                statusLabel = '待處理';
                statusColor = '#D1D5DB';
                actionBtn = `<button class="btn btn-primary w-full btnStartStaffTask" data-task-id="${task.id}" style="margin-top: 1.5rem; justify-content: center;"><i class="fas fa-play" style="margin-right: 8px;"></i> 開始任務</button>`;
            } else if (task.status === 'in_progress') {
                statusLabel = '執行中';
                statusColor = 'var(--accent-blue)';
                actionBtn = `<button class="btn btn-sm w-full btnOpenCompletionModal" data-task-id="${task.id}" style="margin-top: 1.5rem; justify-content: center; background: var(--grad-green); color: white; border: none;"><i class="fas fa-check-double" style="margin-right: 8px;"></i> 完成任務</button>`;
            }

            return `
            <div class="room-type-card" style="padding: 1.5rem;">
                <div class="flex justify-between items-start mb-4">
                    <span class="status-badge" style="background: var(--primary-soft); color: var(--primary-color);">
                        <i class="fas ${categoryIcons[task.category] || 'fa-tasks'}"></i> ${categoryNames[task.category] || task.category}
                    </span>
                    <span style="font-size: 0.7rem; font-weight: 800; color: var(--text-muted); opacity: 0.6;">#${task.ticket_number}</span>
                </div>
                
                <h2 style="font-size: 2rem; font-weight: 900; margin: 0.5rem 0; color: var(--text-main);">
                    ${task.room_number ? 'Room ' + task.room_number : '公共區域'}
                </h2>
                
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 1rem;">
                    <span class="status-dot" style="background: ${statusColor};"></span>
                    <span style="font-size: 0.875rem; font-weight: 600; color: ${statusColor};">${statusLabel}</span>
                </div>

                <div style="background: #F8FAFC; padding: 1rem; border-radius: 12px; border: 1px solid #F1F5F9; font-size: 0.95rem; color: var(--text-main); line-height: 1.6; min-height: 60px;">
                    ${task.description}
                </div>

                ${actionBtn}
            </div>
        `;
        }).join('');
    }

    async function startStaffTask(id) {
        try {
            const res = await fetch(`/api/work-orders/${id}`, {
                method: 'PATCH',
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ status: 'in_progress' })
            });
            if (res.ok) loadStaffTasks();
        } catch (err) { alert('操作失敗'); }
    }

    function openCompletionModal(id) {
        document.getElementById('completionWoId').value = id;
        document.getElementById('woCompletionModal').style.display = 'flex';
    }

    function closeCompletionModal() {
        document.getElementById('woCompletionModal').style.display = 'none';
        document.getElementById('woCompletionForm').reset();
    }

    document.getElementById('woCompletionForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('completionWoId').value;
        const fileInput = document.getElementById('woCompletionImage');

        if (!fileInput.files[0]) {
            alert('請上傳照片');
            return;
        }

        const formData = new FormData();
        formData.append('status', 'completed');
        formData.append('image', fileInput.files[0]);

        const remarks = document.getElementById('woCompletionRemarks').value;
        if (remarks) {
            formData.append('staffRemarks', remarks);
        }

        const btn = e.target.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.innerText = '上傳中...';

        try {
            const res = await fetch(`/api/work-orders/${id}`, {
                method: 'PATCH',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData
            });
            if (res.ok) {
                closeCompletionModal();
                loadStaffTasks();
            } else {
                alert('上傳失敗');
            }
        } catch (err) {
            alert('系統錯誤');
        } finally {
            btn.disabled = false;
            btn.innerText = '上傳並完成';
        }
    });

    // Navigation Event Listeners
    document.getElementById("linkBookings").addEventListener("click", (e) => { e.preventDefault(); showTab("bookings"); });
    document.getElementById("linkBI").addEventListener("click", (e) => { e.preventDefault(); showTab("biDashboard"); });
    document.getElementById("linkStaff").addEventListener("click", (e) => { e.preventDefault(); showTab("staff"); });
    document.getElementById("linkRooms").addEventListener("click", (e) => { e.preventDefault(); showTab("rooms"); });
    document.getElementById("linkWorkOrders").addEventListener("click", (e) => { e.preventDefault(); showTab("workOrders"); });
    document.getElementById("linkInventory").addEventListener("click", (e) => { e.preventDefault(); showTab("inventory"); });
    document.getElementById("linkUsers").addEventListener("click", (e) => { e.preventDefault(); showTab("users"); });

    document.getElementById("btnLogout").addEventListener("click", (e) => { e.preventDefault(); logout(); });

    // Mobile Menu
    document.querySelector(".hamburger").addEventListener("click", toggleSidebar);
    document.getElementById("sidebarOverlay").addEventListener("click", toggleSidebar);

    // Central Event Delegation for dynamic buttons
    document.addEventListener("click", async (e) => {
        const target = e.target.closest("button") || e.target;

        if (target.classList.contains("btn-confirm-booking")) confirmBooking(target.getAttribute("data-id"));
        if (target.classList.contains("btn-edit-booking")) editBooking(target.getAttribute("data-id"));
        if (target.classList.contains("btn-edit-user")) { const user = JSON.parse(target.getAttribute("data-user")); editUser(user); }
        if (target.classList.contains("btn-delete-user")) deleteUser(target.getAttribute("data-id"));
        if (target.classList.contains("btn-view-wo")) viewWorkOrder(target.getAttribute("data-id"));
        if (target.classList.contains("btn-edit-wo")) editWorkOrder(target.getAttribute("data-id"));
        if (target.classList.contains("btn-adjust-inv")) { adjustInventory(target.getAttribute("data-id"), parseInt(target.getAttribute("data-delta"))); }
        if (target.classList.contains("btn-edit-inv")) loadInventoryItemForEdit(target.getAttribute("data-id"));
        if (target.classList.contains("btn-delete-inv")) deleteInventoryItem(target.getAttribute("data-id"));
        if (target.classList.contains("btn-edit-amenities")) { editAmenities(target.getAttribute("data-id"), target.getAttribute("data-name"), JSON.parse(target.getAttribute("data-amenities"))); }
        if (target.classList.contains("btn-manage-instances")) { openInstanceModal(target.getAttribute("data-id"), target.getAttribute("data-name"), target.getAttribute("data-hotel-id")); }
        if (target.classList.contains("btn-trigger-upload")) triggerUpload(target.getAttribute("data-id"));
        if (target.classList.contains("btn-open-gallery")) openGalleryModal(target.getAttribute("data-id"), target.getAttribute("data-name"));
        if (target.classList.contains("btn-delete-room-type")) deleteRoomType(target.getAttribute("data-id"));
        if (target.classList.contains("btn-delete-instance")) deleteInstance(target.getAttribute("data-id"));
        if (target.id === "btnCancelUser" || target.id === "btnCloseUserModal") closeUserModal();
        if (target.id === "btnCancelInventory" || target.id === "btnCloseInventoryModal") closeInventoryModal();
        if (target.id === "btnCloseWoViewModal") closeWoViewModal();
        if (target.id === "btnCloseInstanceModal") closeInstanceModal();
        if (target.id === "btnCloseGalleryModal") closeGalleryModal();
        if (target.id === "btnCancelAmenities" || target.id === "btnCloseAmenitiesModalTop") closeAmenitiesModal();
    });

    // Static Button Listeners
    if (document.getElementById("btnAddNewUser")) {
        document.getElementById("btnAddNewUser").addEventListener("click", () => {
            document.getElementById("userModalTitle").innerText = "新增管理帳號";
            document.getElementById("userForm").reset();
            document.getElementById("editUserId").value = "";
            document.getElementById("userModal").style.display = "flex";
        });
    }
    if (document.getElementById("btnAddNewInventory")) {
        document.getElementById("btnAddNewInventory").addEventListener("click", () => { document.getElementById("inventoryModal").style.display = "flex"; });
    }
    if (document.getElementById("btnAddNewWorkOrder")) {
        document.getElementById("btnAddNewWorkOrder").addEventListener("click", () => { document.getElementById("woModal").style.display = "flex"; });
    }
    if (document.getElementById("btnAddRoomInstance")) {
        document.getElementById("btnAddRoomInstance").addEventListener("click", addRoomInstance);
    }
    if (document.getElementById("btnTriggerGalleryUpload")) {
        document.getElementById("btnTriggerGalleryUpload").addEventListener("click", () => { document.getElementById("galleryImageInput").click(); });
    }

    // Inventory Form Input Handlers
    function setupInventoryFormListeners() {
        const formInputs = ['invName', 'invCode', 'invQuantity', 'invThreshold'];
        
        formInputs.forEach(inputId => {
            const input = document.getElementById(inputId);
            if (input) {
                // 標準邊框顏色
                const normalColor = '#e5e7eb';
                const hoverColor = '#d1d5db';
                const focusColor = input.id === 'invThreshold' ? 'var(--accent-yellow)' : 'var(--primary-color)';
                const focusShadow = input.id === 'invThreshold' 
                    ? '0 0 0 3px rgba(245, 158, 11, 0.1)' 
                    : '0 0 0 3px rgba(59, 130, 246, 0.1)';
                
                input.addEventListener('mouseover', function() {
                    this.style.borderColor = hoverColor;
                });
                
                input.addEventListener('mouseout', function() {
                    this.style.borderColor = normalColor;
                });
                
                input.addEventListener('focus', function() {
                    this.style.borderColor = focusColor;
                    this.style.boxShadow = focusShadow;
                });
                
                input.addEventListener('blur', function() {
                    this.style.borderColor = normalColor;
                    this.style.boxShadow = 'none';
                });
            }
        });
    }

    // Dashboard Button Listeners
    const btnRefreshBIDashboard = document.getElementById('btnRefreshBIDashboard');
    if (btnRefreshBIDashboard) {
        btnRefreshBIDashboard.addEventListener('click', loadBIDashboard);
    }

    const btnRefreshStaffTasks = document.getElementById('btnRefreshStaffTasks');
    if (btnRefreshStaffTasks) {
        btnRefreshStaffTasks.addEventListener('click', loadStaffTasks);
    }

    // Staff Tasks Dynamic Button Listeners
    document.addEventListener('click', function(e) {
        if (e.target.closest('.btnStartStaffTask')) {
            const taskId = e.target.closest('.btnStartStaffTask').dataset.taskId;
            startStaffTask(taskId);
        }
        if (e.target.closest('.btnOpenCompletionModal')) {
            const taskId = e.target.closest('.btnOpenCompletionModal').dataset.taskId;
            openCompletionModal(taskId);
        }
    });

    // Initialize inventory form listeners when modal opens
    const inventoryModal = document.getElementById('inventoryModal');
    if (inventoryModal) {
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.attributeName === 'style') {
                    const isVisible = inventoryModal.style.display === 'flex' || inventoryModal.style.display === 'block';
                    if (isVisible) {
                        setupInventoryFormListeners();
                    }
                }
            });
        });
        observer.observe(inventoryModal, { attributes: true });
    }

    // Initial setup
    setupInventoryFormListeners();

</script>